<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Sign In – ALSHAPRAWY STORE</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #00c2ff;
      --primary-glow: rgba(0,194,255,0.2);
      --accent2: #a855f7;
      --dark: #080e1a;
      --dark2: #0d1526;
      --dark3: #111d33;
      --card: #0f1a2e;
      --border: rgba(0,194,255,0.15);
      --text: #e2eaf5;
      --muted: #6b82a3;
      --green: #00e5a0;
    }

    html { scroll-behavior: smooth; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--dark);
      color: var(--text);
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* noise */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    /* ── NAVBAR ── */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(8,14,26,0.96);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 1.25rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .navbar h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 3px;
      background: linear-gradient(90deg, var(--primary), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .navbar-links { display: flex; gap: 0.25rem; }

    .navbar-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 0.45rem 0.85rem;
      border-radius: 8px;
      border: 1px solid transparent;
      transition: all 0.2s;
      /* larger tap target */
      min-height: 44px;
      display: flex;
      align-items: center;
    }

    .navbar-links a:hover,
    .navbar-links a:active {
      color: var(--primary);
      border-color: var(--border);
      background: rgba(0,194,255,0.07);
    }

    /* ── PAGE BODY ── */
    .page-body {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.25rem 3rem;
    }

    /* ambient glow */
    .page-body::before {
      content: '';
      position: fixed;
      top: 40%;
      left: 50%;
      transform: translate(-50%,-50%);
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(0,194,255,0.08), transparent 65%);
      pointer-events: none;
    }

    /* ── LOGO MARK (mobile top branding) ── */
    .mobile-brand {
      text-align: center;
      margin-bottom: 2rem;
    }

    .mobile-brand .brand-icon {
      width: 64px; height: 64px;
      background: linear-gradient(135deg, var(--primary), var(--accent2));
      border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 0.9rem;
      box-shadow: 0 12px 40px var(--primary-glow);
    }

    .mobile-brand h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 2px;
    }

    .mobile-brand h2 span { color: var(--primary); }

    .mobile-brand p {
      font-size: 0.83rem;
      color: var(--muted);
      margin-top: 0.3rem;
    }

    /* ── CARD ── */
    .signin-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      width: 100%;
      max-width: 440px;
      padding: 2rem 1.75rem;
      box-shadow: 0 24px 80px rgba(0,0,0,0.45);
      animation: fadeUp 0.4s cubic-bezier(0.4,0,0.2,1) both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .form-header { margin-bottom: 1.75rem; }

    .form-header h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 2px;
      color: var(--text);
      margin-bottom: 0.3rem;
    }

    .form-header p {
      font-size: 0.83rem;
      color: var(--muted);
    }

    .form-header p a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
    }

    /* ── FIELDS ── */
    .field { margin-bottom: 1.1rem; }

    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--muted);
      margin-bottom: 0.5rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    input[type="text"],
    input[type="email"],
    input[type="password"] {
      width: 100%;
      /* 48px min height for mobile tap targets */
      padding: 0.85rem 1rem;
      min-height: 48px;
      background: var(--dark2);
      border: 1.5px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      font-family: 'Outfit', sans-serif;
      font-size: 1rem; /* ≥16px prevents iOS zoom */
      color: var(--text);
      outline: none;
      transition: all 0.25s;
      -webkit-appearance: none;
      appearance: none;
    }

    input:focus {
      border-color: var(--primary);
      background: rgba(0,194,255,0.04);
      box-shadow: 0 0 0 3px var(--primary-glow);
    }

    input::placeholder { color: #3a4d6a; }

    /* ── FIELD META ── */
    .field-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.5rem;
    }

    .field-meta label { margin-bottom: 0; }

    .forgot {
      font-size: 0.78rem;
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      min-height: 44px;
      display: flex;
      align-items: center;
    }

    /* ── SUBMIT ── */
    button[type="submit"] {
      width: 100%;
      min-height: 52px;
      padding: 0.9rem 1rem;
      background: var(--primary);
      color: var(--dark);
      border: none;
      border-radius: 12px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 2px;
      cursor: pointer;
      transition: all 0.25s;
      margin-top: 0.75rem;
      box-shadow: 0 4px 20px var(--primary-glow);
      /* prevent iOS double-tap zoom */
      touch-action: manipulation;
    }

    button[type="submit"]:active {
      transform: scale(0.98);
      background: #00aaee;
    }

    /* ── TRUST BADGES ── */
    .trust-badges {
      display: flex;
      justify-content: center;
      gap: 1.25rem;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    .badge {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 500;
    }

    .badge-icon {
      width: 36px; height: 36px;
      background: var(--dark3);
      border: 1px solid var(--border);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    /* ── SIGNUP LINK ── */
    .signup-link {
      margin-top: 1.5rem;
      text-align: center;
      font-size: 0.85rem;
      color: var(--muted);
    }

    .signup-link a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 700;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }

    /* ── DESKTOP ENHANCEMENTS ── */
    @media (min-width: 640px) {
      .navbar { padding: 0 3rem; height: 70px; }
      .navbar h1 { font-size: 1.8rem; }

      .page-body { padding: 3rem 2rem; }

      /* Show split-panel layout on desktop */
      .mobile-brand { display: none; }

      .signin-card {
        max-width: 820px;
        padding: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        overflow: hidden;
      }

      /* Panel left only shows on desktop */
      .panel-left {
        display: flex !important;
        background: linear-gradient(135deg, #003d5c 0%, #1a0540 100%);
        border-right: 1px solid var(--border);
        padding: 3rem 2.5rem;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
      }

      .panel-left::before {
        content: '';
        position: absolute;
        top: -80px; right: -80px;
        width: 250px; height: 250px;
        border-radius: 50%;
        background: rgba(0,194,255,0.08);
        pointer-events: none;
      }

      .panel-left::after {
        content: '';
        position: absolute;
        bottom: -60px; left: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(168,85,247,0.07);
        pointer-events: none;
      }

      .brand-mark {
        width: 50px; height: 50px;
        background: rgba(0,194,255,0.15);
        border: 1px solid var(--border);
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 2rem;
        position: relative; z-index: 1;
      }

      .panel-left h2 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2rem;
        letter-spacing: 2px;
        line-height: 1.1;
        margin-bottom: 0.75rem;
        position: relative; z-index: 1;
        color: var(--text);
      }

      .panel-left h2 span { color: var(--primary); }

      .panel-left > div > p {
        font-size: 0.88rem;
        color: var(--muted);
        line-height: 1.7;
        position: relative; z-index: 1;
      }

      .features { position: relative; z-index: 1; }

      .feature-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.9rem;
      }

      .feature-icon {
        width: 34px; height: 34px;
        background: rgba(0,194,255,0.1);
        border: 1px solid var(--border);
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.95rem;
        flex-shrink: 0;
      }

      .feature-item span {
        font-size: 0.83rem;
        color: var(--muted);
        font-weight: 500;
      }

      .panel-right {
        padding: 3rem 2.5rem;
      }

      /* hide trust badges inside card on desktop, they're in panel-left */
      .trust-badges { display: none; }
    }

    /* panel-left hidden on mobile */
    .panel-left { display: none; }
    .panel-right { width: 100%; }
  </style>
</head>
<body>

  <!-- ── NAVBAR ── -->
  <header class="navbar">
    <h1>ALSHAPRAWY</h1>
    <div class="navbar-links">
      <a href="/">Home</a>
      <a href="/signup">Sign Up</a>
    </div>
  </header>

  <!-- ── PAGE BODY ── -->
  <div class="page-body">

    <!-- Mobile branding (hidden on desktop) -->
    <div class="mobile-brand">
      <div class="brand-icon">🖥️</div>
      <h2>WELCOME <span>BACK</span></h2>
      <p>Sign in to your store account</p>
    </div>

    <div class="signin-card">

      <!-- LEFT PANEL (desktop only) -->
      <div class="panel-left">
        <div>
          <div class="brand-mark">🖥️</div>
          <h2>WELCOME <span>BACK</span></h2>
          <p>Sign in and get back to building your perfect setup. Your cart and orders are waiting.</p>
        </div>
        <div class="features">
          <div class="feature-item">
            <div class="feature-icon">🛡️</div>
            <span>100% original products guaranteed</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">🚚</div>
            <span>Fast delivery across Egypt</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">💬</div>
            <span>24/7 expert support</span>
          </div>
        </div>
      </div>

      <!-- RIGHT PANEL (form) -->
      <div class="panel-right">
        <div class="form-header">
          <h3>SIGN IN</h3>
          <p>No account? <a href="/signup">Sign up free →</a></p>
        </div>

        <form action="/signin" method="POST">
          <div class="field">
            <label for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              autocomplete="email"
              inputmode="email"
              required
            >
          </div>

          <div class="field">
            <div class="field-meta">
              <label for="password">Password</label>
              <a href="/forgot-password" class="forgot">Forgot?</a>
            </div>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter your password"
              autocomplete="current-password"
              required
            >
          </div>

          <button type="submit">SIGN IN →</button>
        </form>

        <!-- Mobile trust badges -->
        <div class="trust-badges">
          <div class="badge">
            <div class="badge-icon">🛡️</div>
            Secure
          </div>
          <div class="badge">
            <div class="badge-icon">🔒</div>
            Private
          </div>
          <div class="badge">
            <div class="badge-icon">✅</div>
            Verified
          </div>
        </div>

        <div class="signup-link">
          New here? <a href="/signup">Create a free account</a>
        </div>
      </div>

    </div>
  </div>

</body>
</html>