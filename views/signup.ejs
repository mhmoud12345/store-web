<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up</title>
  <link rel="stylesheet" href="/css/signup.css">
</head>

<body>

  <header class="navbar">
    <h1>✦ ALSHABRAWY</h1>
    <nav>

      <a href="/">Home</a>
      <!-- <a href="#">Features</a> -->
      <!-- <a href="#">Pricing</a> -->
      <a href="/signin">Sign In</a>
    </nav>
  </header>

  <div class="page-body">
    <div class="signup-card">

      <div class="panel-left">
        <div>
          <div class="brand-mark">✦</div>
          <h2>Join thousands of happy users</h2>
          <p>Create your free account and start building something amazing today.</p>
        </div>
        <div class="features">
          <div class="feature-item">
            <div class="feature-icon">🔒</div>
            <span>Secure &amp; private by default</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">⚡</div>
            <span>Get started in under a minute</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">💳</div>
            <span>No credit card required</span>
          </div>
        </div>
      </div>

      <div class="panel-right">
        <div class="form-header">
          <h3>Create Account</h3>
          <p>Already have one? <a href="/signin">Sign in</a></p>
        </div>

        <form action="/signup" method="POST">
          <div class="field">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Jane Doe" required>
          </div>
          <div class="field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" required>
          </div>
          <div class="field">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="Min. 8 characters" required>
            <div class="strength-bar"><div class="strength-fill" id="strength-fill"></div></div>
          </div>
          <input type="hidden" name="role" value="user">
          <button type="submit">Create Account →</button>
        </form>

        <div class="terms">
          By signing up you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
        </div>
      </div>

    </div>
  </div>

  <script>
    const pwd  = document.getElementById('password');
    const fill = document.getElementById('strength-fill');
    pwd.addEventListener('input', () => {
      const v = pwd.value;
      let score = 0;
      if (v.length >= 8)           score++;
      if (/[A-Z]/.test(v))         score++;
      if (/[0-9]/.test(v))         score++;
      if (/[^A-Za-z0-9]/.test(v))  score++;
      const widths = ['0%','30%','55%','80%','100%'];
      const colors = ['transparent','#f59e0b','#f59e0b','#6366f1','#10b981'];
      fill.style.width      = widths[score];
      fill.style.background = colors[score];
    });
  </script>
</body>
</html>