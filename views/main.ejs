<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ALSHAPRAWY STORE – Computer Accessories</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #00c2ff;
      --primary-glow: rgba(0,194,255,0.25);
      --accent: #ff6b2b;
      --accent2: #a855f7;
      --dark: #080e1a;
      --dark2: #0d1526;
      --dark3: #111d33;
      --card: #0f1a2e;
      --border: rgba(0,194,255,0.15);
      --text: #e2eaf5;
      --muted: #6b82a3;
      --green: #00e5a0;
      --red: #ff4757;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--dark);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── NOISE OVERLAY ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.6;
    }

    /* ── NAVBAR ── */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(8,14,26,0.92);
      backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--border);
      padding: 0 3rem;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .navbar h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 3px;
      background: linear-gradient(90deg, var(--primary), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .navbar nav {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .navbar nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      border: 1px solid transparent;
      transition: all 0.25s;
    }

    .navbar nav a:hover {
      color: var(--primary);
      border-color: var(--border);
      background: rgba(0,194,255,0.06);
    }

    .navbar nav a.btn-primary {
      background: var(--primary);
      color: var(--dark);
      font-weight: 700;
      border-color: var(--primary);
    }

    .navbar nav a.btn-primary:hover {
      background: #00aaee;
      color: var(--dark);
      box-shadow: 0 0 20px var(--primary-glow);
    }

    /* ── HERO BANNER ── */
    .hero {
      position: relative;
      z-index: 1;
      padding: 5rem 3rem 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      max-width: 1300px;
      margin: 0 auto;
      overflow: hidden;
    }

    .hero-glow {
      position: absolute;
      top: -100px; right: -100px;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0,194,255,0.12), transparent 70%);
      pointer-events: none;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(0,229,160,0.1);
      border: 1px solid rgba(0,229,160,0.3);
      color: var(--green);
      font-size: 0.78rem;
      font-weight: 600;
      padding: 0.35rem 0.85rem;
      border-radius: 100px;
      letter-spacing: 0.05em;
      margin-bottom: 1.25rem;
    }

    .hero-badge::before {
      content: '';
      width: 7px; height: 7px;
      background: var(--green);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.4); }
    }

    .hero h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 6vw, 5rem);
      line-height: 0.95;
      letter-spacing: 2px;
      margin-bottom: 1.25rem;
    }

    .hero h2 span {
      background: linear-gradient(135deg, var(--primary), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.7;
      max-width: 440px;
      margin-bottom: 2rem;
    }

    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1.75rem;
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s;
      cursor: pointer;
      border: none;
    }

    .btn-cyan {
      background: var(--primary);
      color: var(--dark);
    }

    .btn-cyan:hover {
      background: #00aaee;
      transform: translateY(-2px);
      box-shadow: 0 8px 28px var(--primary-glow);
    }

    .btn-outline {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border);
    }

    .btn-outline:hover {
      border-color: var(--primary);
      color: var(--primary);
      transform: translateY(-2px);
    }

    .hero-stats {
      display: flex;
      gap: 2rem;
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .stat { text-align: center; }

    .stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      color: var(--primary);
      letter-spacing: 1px;
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--muted);
      font-weight: 500;
    }

    /* Hero visual */
    .hero-visual {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-card-stack {
      position: relative;
      width: 100%;
      height: 320px;
    }

    .hero-card-stack .hc {
      position: absolute;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }

    .hc1 { width: 160px; height: 160px; top: 0; left: 10%; transform: rotate(-6deg); animation: float1 5s ease-in-out infinite; }
    .hc2 { width: 140px; height: 140px; top: 40px; right: 10%; transform: rotate(4deg); animation: float2 6s ease-in-out infinite; }
    .hc3 { width: 130px; height: 130px; bottom: 10px; left: 25%; transform: rotate(-3deg); animation: float3 4.5s ease-in-out infinite; }

    @keyframes float1 { 0%,100%{ transform: rotate(-6deg) translateY(0) } 50%{ transform: rotate(-6deg) translateY(-12px) } }
    @keyframes float2 { 0%,100%{ transform: rotate(4deg) translateY(0) } 50%{ transform: rotate(4deg) translateY(-16px) } }
    @keyframes float3 { 0%,100%{ transform: rotate(-3deg) translateY(0) } 50%{ transform: rotate(-3deg) translateY(-10px) } }

    /* ── SECTION WRAPPER ── */
    .section {
      position: relative;
      z-index: 1;
      max-width: 1300px;
      margin: 0 auto;
      padding: 3.5rem 3rem;
    }

    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: 2px;
    }

    .section-title span { color: var(--primary); }

    .section-subtitle {
      font-size: 0.85rem;
      color: var(--muted);
      margin-top: 0.3rem;
    }

    .view-all {
      font-size: 0.85rem;
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 0.3rem;
      transition: gap 0.2s;
      white-space: nowrap;
    }

    .view-all:hover { gap: 0.6rem; }

    /* ── CATEGORY STRIP ── */
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 1rem;
    }

    .cat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem 1rem;
      text-align: center;
      text-decoration: none;
      color: var(--text);
      transition: all 0.3s;
      cursor: pointer;
    }

    .cat-card:hover {
      border-color: var(--primary);
      background: rgba(0,194,255,0.07);
      transform: translateY(-4px);
      box-shadow: 0 12px 30px rgba(0,194,255,0.12);
    }

    .cat-icon {
      font-size: 2rem;
      margin-bottom: 0.6rem;
    }

    .cat-name {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--muted);
    }

    .cat-card:hover .cat-name { color: var(--primary); }

    /* ── NEW ARRIVALS BANNER ── */
    .new-arrivals-banner {
      position: relative;
      z-index: 1;
      background: linear-gradient(135deg, var(--dark3) 0%, #0a1628 100%);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      overflow: hidden;
    }

    .new-arrivals-banner::before {
      content: '';
      position: absolute;
      left: -150px; top: -150px;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(168,85,247,0.15), transparent 70%);
      pointer-events: none;
    }

    .new-arrivals-banner::after {
      content: '';
      position: absolute;
      right: -100px; bottom: -100px;
      width: 350px; height: 350px;
      background: radial-gradient(circle, rgba(0,194,255,0.1), transparent 70%);
      pointer-events: none;
    }

    .banner-inner {
      position: relative;
      z-index: 1;
      max-width: 1300px;
      margin: 0 auto;
      padding: 3rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .banner-tag {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 3px;
      color: var(--accent2);
      margin-bottom: 0.5rem;
    }

    .banner-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      letter-spacing: 2px;
      line-height: 1;
    }

    .banner-title span { color: var(--primary); }

    .banner-desc {
      color: var(--muted);
      font-size: 0.9rem;
      margin-top: 0.75rem;
      max-width: 420px;
    }

    /* ── PRODUCT GRID ── */
    .product-container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.25rem;
    }

    .product {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
      display: flex;
      flex-direction: column;
      animation: fadeUp 0.5s ease both;
    }

    .product:nth-child(1) { animation-delay: 0.05s; }
    .product:nth-child(2) { animation-delay: 0.1s; }
    .product:nth-child(3) { animation-delay: 0.15s; }
    .product:nth-child(4) { animation-delay: 0.2s; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .product:hover {
      border-color: var(--primary);
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0,0,0,0.35), 0 0 0 1px rgba(0,194,255,0.15);
    }

    .product-img-wrap {
      position: relative;
      background: var(--dark2);
      padding: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 180px;
      overflow: hidden;
    }

    .product-img-wrap::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 50%, rgba(0,194,255,0.08), transparent 70%);
    }

    .product img {
      width: 100%;
      max-height: 160px;
      object-fit: contain;
      position: relative;
      z-index: 1;
      transition: transform 0.4s ease;
    }

    .product:hover img { transform: scale(1.06); }

    .product-badge {
      position: absolute;
      top: 0.75rem;
      left: 0.75rem;
      background: var(--accent);
      color: white;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.25rem 0.6rem;
      border-radius: 6px;
      letter-spacing: 0.05em;
      z-index: 2;
    }

    .product-info {
      padding: 1.25rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .product h3 {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.4rem;
      line-height: 1.4;
    }

    .product .description {
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.5;
      flex: 1;
      margin-bottom: 1rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .price {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 1px;
      color: var(--primary);
    }

    .price-sub {
      font-size: 0.7rem;
      color: var(--muted);
      font-family: 'Outfit', sans-serif;
    }

    .actions {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      padding: 0 1.25rem 1.25rem;
    }

    .actions a {
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 600;
      padding: 0.45rem 0.9rem;
      border-radius: 8px;
      transition: all 0.25s;
      border: 1px solid transparent;
    }

    .add-to-cart {
      background: var(--primary);
      color: var(--dark);
    }

    .add-to-cart:hover {
      background: #00aaee;
      box-shadow: 0 4px 16px var(--primary-glow);
      transform: translateY(-1px);
    }

    .details {
      background: transparent;
      color: var(--muted);
      border-color: var(--border) !important;
    }

    .details:hover { color: var(--text); border-color: var(--muted) !important; }

    .edit {
      background: rgba(168,85,247,0.15);
      color: var(--accent2);
      border-color: rgba(168,85,247,0.25) !important;
    }

    .edit:hover { background: rgba(168,85,247,0.25); }

    .delete {
      background: rgba(255,71,87,0.1);
      color: var(--red);
      border-color: rgba(255,71,87,0.2) !important;
    }

    .delete:hover { background: rgba(255,71,87,0.2); }

    /* ── DEALS BANNER ── */
    .deals-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    .deal-card {
      position: relative;
      border-radius: 18px;
      padding: 2rem;
      overflow: hidden;
      text-decoration: none;
      display: block;
      transition: transform 0.3s;
    }

    .deal-card:hover { transform: translateY(-4px); }

    .deal-card.cyan {
      background: linear-gradient(135deg, #003d5c, #005080);
      border: 1px solid rgba(0,194,255,0.3);
    }

    .deal-card.orange {
      background: linear-gradient(135deg, #3d1a00, #5c2800);
      border: 1px solid rgba(255,107,43,0.3);
    }

    .deal-card.purple {
      background: linear-gradient(135deg, #200b3d, #2d1050);
      border: 1px solid rgba(168,85,247,0.3);
    }

    .deal-card.green {
      background: linear-gradient(135deg, #002b1e, #003d2a);
      border: 1px solid rgba(0,229,160,0.3);
    }

    .deal-emoji {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
    }

    .deal-tag {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.3rem;
      opacity: 0.7;
    }

    .cyan .deal-tag { color: var(--primary); }
    .orange .deal-tag { color: var(--accent); }
    .purple .deal-tag { color: var(--accent2); }
    .green .deal-tag { color: var(--green); }

    .deal-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 1px;
      color: white;
      margin-bottom: 0.4rem;
    }

    .deal-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.5;
    }

    .deal-arrow {
      position: absolute;
      right: 1.5rem;
      bottom: 1.5rem;
      font-size: 1.2rem;
      color: rgba(255,255,255,0.3);
      transition: all 0.3s;
    }

    .deal-card:hover .deal-arrow { color: rgba(255,255,255,0.8); transform: translate(4px,-4px); }

    /* ── WHY US ── */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
    }

    .feature-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.75rem 1.5rem;
      transition: all 0.3s;
    }

    .feature-card:hover {
      border-color: var(--primary);
      background: rgba(0,194,255,0.05);
      transform: translateY(-3px);
    }

    .feature-icon-wrap {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      margin-bottom: 1rem;
    }

    .fi-cyan { background: rgba(0,194,255,0.12); }
    .fi-orange { background: rgba(255,107,43,0.12); }
    .fi-purple { background: rgba(168,85,247,0.12); }
    .fi-green { background: rgba(0,229,160,0.12); }

    .feature-card h4 {
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
    }

    .feature-card p {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── NEWSLETTER ── */
    .newsletter {
      position: relative;
      z-index: 1;
      background: var(--dark3);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .newsletter-inner {
      max-width: 600px;
      margin: 0 auto;
      padding: 4rem 3rem;
      text-align: center;
    }

    .newsletter h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.2rem;
      letter-spacing: 2px;
      margin-bottom: 0.5rem;
    }

    .newsletter h3 span { color: var(--primary); }

    .newsletter p {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 1.75rem;
    }

    .newsletter-form {
      display: flex;
      gap: 0.75rem;
      max-width: 420px;
      margin: 0 auto;
    }

    .newsletter-form input {
      flex: 1;
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      font-family: 'Outfit', sans-serif;
      font-size: 0.88rem;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s;
    }

    .newsletter-form input:focus { border-color: var(--primary); }

    .newsletter-form input::placeholder { color: var(--muted); }

    .newsletter-form button {
      background: var(--primary);
      color: var(--dark);
      border: none;
      border-radius: 10px;
      padding: 0.75rem 1.25rem;
      font-family: 'Outfit', sans-serif;
      font-size: 0.88rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .newsletter-form button:hover {
      background: #00aaee;
      box-shadow: 0 4px 20px var(--primary-glow);
    }

    /* ── FOOTER ── */
    footer {
      position: relative;
      z-index: 1;
      background: var(--dark2);
      border-top: 1px solid var(--border);
    }

    .footer-inner {
      max-width: 1300px;
      margin: 0 auto;
      padding: 3.5rem 3rem 2rem;
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 2.5rem;
    }

    .footer-brand h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 3px;
      background: linear-gradient(90deg, var(--primary), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.75rem;
    }

    .footer-brand p {
      font-size: 0.83rem;
      color: var(--muted);
      line-height: 1.7;
      max-width: 240px;
    }

    .footer-col h4 {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 1rem;
      letter-spacing: 0.05em;
    }

    .footer-col a {
      display: block;
      font-size: 0.83rem;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 0.55rem;
      transition: color 0.2s;
    }

    .footer-col a:hover { color: var(--primary); }

    .footer-bottom {
      border-top: 1px solid var(--border);
      margin: 2rem 3rem 0;
      padding: 1.5rem 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      max-width: calc(1300px - 6rem);
      margin-left: auto;
      margin-right: auto;
    }

    .footer-bottom p {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .footer-socials { display: flex; gap: 0.75rem; }

    .social-btn {
      width: 36px; height: 36px;
      background: var(--dark3);
      border: 1px solid var(--border);
      border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
      text-decoration: none;
      transition: all 0.25s;
    }

    .social-btn:hover {
      border-color: var(--primary);
      background: rgba(0,194,255,0.1);
      transform: translateY(-2px);
    }

    /* ── TICKER ── */
    .ticker-wrap {
      background: var(--primary);
      overflow: hidden;
      padding: 0.55rem 0;
      position: relative;
      z-index: 1;
    }

    .ticker-track {
      display: flex;
      white-space: nowrap;
      animation: ticker 25s linear infinite;
    }

    .ticker-item {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.85rem;
      letter-spacing: 2px;
      color: var(--dark);
      padding: 0 2.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .ticker-item::after { content: '✦'; opacity: 0.5; }

    @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .footer-inner { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .navbar { padding: 0 1.5rem; }
      .hero { grid-template-columns: 1fr; padding: 3rem 1.5rem; }
      .hero-visual { display: none; }
      .section { padding: 2.5rem 1.5rem; }
      .banner-inner { padding: 2.5rem 1.5rem; }
      .deals-row { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; padding: 2.5rem 1.5rem; }
      .footer-bottom { margin: 1.5rem 1.5rem 0; }
      .newsletter-inner { padding: 3rem 1.5rem; }
      .newsletter-form { flex-direction: column; }
    }

    @media (max-width: 480px) {
      .footer-inner { grid-template-columns: 1fr; }
      .navbar h1 { font-size: 1.3rem; }
    }
  </style>
</head>
