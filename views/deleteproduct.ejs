<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delete Product – ALSHAPRAWY STORE</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/deleteproduct.css">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #00c2ff;
      --primary-glow: rgba(0,194,255,0.2);
      --accent2: #a855f7;
      --dark: #080e1a;
      --dark2: #0d1526;
      --dark3: #111d33;
      --card: #0f1a2e;
      --border: rgba(0,194,255,0.15);
      --text: #e2eaf5;
      --muted: #6b82a3;
      --red: #ff4757;
      --red-glow: rgba(255,71,87,0.2);
      --red-border: rgba(255,71,87,0.25);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--dark);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* ── NOISE ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.6;
    }

    /* ── NAVBAR ── */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(8,14,26,0.95);
      backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--border);
      padding: 0 3rem;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .navbar h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 3px;
      background: linear-gradient(90deg, var(--primary), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .navbar nav {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .navbar nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      border: 1px solid transparent;
      transition: all 0.25s;
    }

    .navbar nav a:hover {
      color: var(--primary);
      border-color: var(--border);
      background: rgba(0,194,255,0.06);
    }

    /* ── MAIN ── */
    main {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 2rem;
    }

    /* ── GLOW BG ── */
    main::before {
      content: '';
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(255,71,87,0.07), transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── FORM CONTAINER ── */
    .form-container {
      position: relative;
      z-index: 1;
      background: var(--card);
      border: 1px solid var(--red-border);
      border-radius: 20px;
      width: 100%;
      max-width: 520px;
      overflow: hidden;
      box-shadow: 0 24px 80px rgba(0,0,0,0.5), 0 0 0 1px var(--red-border);
      animation: fadeUp 0.4s cubic-bezier(0.4,0,0.2,1) both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── WARNING HEADER ── */
    .warning-header {
      background: linear-gradient(135deg, rgba(255,71,87,0.12), rgba(255,71,87,0.06));
      border-bottom: 1px solid var(--red-border);
      padding: 2rem 2rem 1.5rem;
      text-align: center;
    }

    .warning-icon {
      width: 64px;
      height: 64px;
      background: rgba(255,71,87,0.12);
      border: 1px solid var(--red-border);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 1rem;
      animation: wobble 3s ease-in-out infinite;
    }

    @keyframes wobble {
      0%,100% { transform: rotate(-4deg); }
      50%      { transform: rotate(4deg); }
    }

    .warning-header h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 2px;
      color: var(--red);
      margin-bottom: 0.4rem;
    }

    .warning-header p {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.5;
    }

    /* ── PRODUCT CARD ── */
    .product-card {
      margin: 1.75rem 2rem;
      background: var(--dark2);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }

    .product-img-wrap {
      background: var(--dark3);
      padding: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 160px;
      position: relative;
    }

    .product-img-wrap::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle, rgba(255,71,87,0.06), transparent 70%);
    }

    .product-card img {
      max-width: 100%;
      max-height: 140px;
      object-fit: contain;
      position: relative;
      z-index: 1;
      border-radius: 6px;
    }

    .product-info {
      padding: 1.25rem 1.5rem 1.5rem;
    }

    .product-card h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.4rem;
      line-height: 1.4;
    }

    .product-card .description {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.5;
      margin-bottom: 0.9rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .price-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .price {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 1px;
      color: var(--primary);
    }

    .price-label {
      font-size: 0.72rem;
      color: var(--muted);
      font-family: 'Outfit', sans-serif;
    }

    .irreversible-note {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: rgba(255,71,87,0.07);
      border: 1px solid var(--red-border);
      border-radius: 8px;
      padding: 0.7rem 1rem;
      margin: 0 2rem 1.75rem;
      font-size: 0.8rem;
      color: rgba(255,71,87,0.85);
    }

    .irreversible-note span { font-size: 1rem; }

    /* ── ACTIONS ── */
    .form-actions {
      padding: 0 2rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.85rem 1rem;
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-size: 0.92rem;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.3s;
      cursor: pointer;
      border: none;
      letter-spacing: 0.02em;
    }

    .delete-btn {
      background: var(--red);
      color: white;
    }

    .delete-btn:hover {
      background: #e63946;
      box-shadow: 0 8px 28px var(--red-glow);
      transform: translateY(-2px);
    }

    .delete-btn:active {
      transform: translateY(0) scale(0.99);
    }

    .cancel-btn {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
    }

    .cancel-btn:hover {
      border-color: var(--primary);
      color: var(--primary);
      transform: translateY(-2px);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .navbar { padding: 0 1.5rem; }
      .navbar h1 { font-size: 1.3rem; }
      main { padding: 2rem 1rem; }
    }

    @media (max-width: 480px) {
      .warning-header { padding: 1.5rem 1.5rem 1.25rem; }
      .product-card { margin: 1.5rem 1.5rem; }
      .irreversible-note { margin: 0 1.5rem 1.5rem; }
      .form-actions { padding: 0 1.5rem 1.75rem; }
    }
  </style>
</head>
<body>

  <!-- ── NAVBAR ── -->
  <header class="navbar">
    <h1>ALSHAPRAWY STORE</h1>
    <nav>
      <a href="/">Shop</a>
      <a href="/newproduct">New Product</a>
      <a href="/orders">Orders</a>
    </nav>
  </header>

  <!-- ── MAIN ── -->
  <main>
    <div class="form-container">

      <!-- Warning Header -->
      <div class="warning-header">
        <div class="warning-icon">🗑️</div>
        <h2>Delete Product</h2>
        <p>You're about to permanently remove this product from the store.</p>
      </div>

      <!-- Product Preview -->
      <div class="product-card">
        <div class="product-img-wrap">
          <img src="<%= product.image %>" alt="<%= product.name %>">
        </div>
        <div class="product-info">
          <h3><%= product.name %></h3>
          <p class="description"><%= product.description %></p>
          <div class="price-row">
            <div>
              <div class="price"><%= product.price %> EGP</div>
              <div class="price-label">Current price</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Warning Note -->
      <div class="irreversible-note">
        <span>⚠️</span>
        This action is irreversible. The product will be permanently deleted.
      </div>

      <!-- Actions -->
      <form action="/deleteproduct" method="POST">
        <input type="hidden" name="_id" value="<%= product._id %>">
        <div class="form-actions">
          <button class="btn delete-btn" type="submit">🗑️ Yes, Delete Product</button>
          <a href="/" class="btn cancel-btn">← Cancel, Keep Product</a>
        </div>
      </form>

    </div>
  </main>

</body>
</html>
